    navigator.mediaDevices.enumerateDevices().then(function(list){
      var cams = 0, mics = 0;
      list.forEach(function(d){ if (d.kind === 'videoinput') cams++; else if (d.kind === 'audioinput') mics++; });
      S.media = { cams: cams, mics: mics };
