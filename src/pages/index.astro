  }

  var adblockOn = null, adblockRegion = null;
  function renderOrigin(){
    var votes = {};
    function vote(cc, n){ if (cc) votes[cc] = (votes[cc]||0) + (n||1); }

    // 1) IP — nezávislý a silný signál (váha 2)
    var ipCC = (S.whoami && S.whoami.geo && S.whoami.geo.country) || null;
    if (ipCC){ set('o-ip', flag(ipCC), 'hot'); vote(ipCC, 2); }
    else set('o-ip', tr('(jen na nasazeném webu)','(only on deployed site)'));

    // 2) timezone (nezávislý)
    var tz = null; try { tz = Intl.DateTimeFormat().resolvedOptions().timeZone; } catch(e){}
    var tzCC = tzCountry(tz);
    set('o-tz', tz ? (tz + (tzCC ? '  → ' + flag(tzCC) : '')) : '—', tzCC ? 'hot':''); vote(tzCC);

    // 3) jazyk (nezávislý)
    var lang = (navigator.languages && navigator.languages[0]) || navigator.language || null;
    var langCC = langCountry(lang);
    set('o-lang', lang ? (lang + (langCC ? '  → ' + flag(langCC) : '')) : '—', langCC ? 'hot':''); vote(langCC);

    // 4) locale / formát čísel — odvozeno z jazyka (jen zobrazení, NEHLASUJE,
    //    aby se stejný signál nepočítal dvakrát).
    try {
      var loc = new Intl.NumberFormat().resolvedOptions().locale;
      var locCC = langCountry(loc);
      set('o-locale', (1234567.89).toLocaleString() + '  ·  ' + loc + (locCC ? '  → ' + flag(locCC) : ''), locCC ? 'hot':'');
    } catch(e){ set('o-locale', '—'); }

    // 5) adblock + regionální filtr (doplní se asynchronně)
    if (adblockOn === null) set('o-adblock', tr('zjišťuji…','checking…'));
    else set('o-adblock', adblockOn ? tr('ANO — máš blokovač','YES — blocker on') : tr('ne','no'), adblockOn ? 'hot':'');
    if (adblockRegion){ set('o-adregion', flag(adblockRegion) + tr('  (podle filtru)','  (by filter)'), 'danger'); vote(adblockRegion, 2); }
    else if (adblockOn === false) set('o-adregion', tr('—','—'));
    else set('o-adregion', tr('zjišťuji…','checking…'));

    // verdikt — země s nejvíc hlasy
    var best = null, bestN = 0, total = 0;
    Object.keys(votes).forEach(function(cc){ total += votes[cc]; if (votes[cc] > bestN){ bestN = votes[cc]; best = cc; } });
    S.originBest = best;
    if (S.dossierReady) renderDossier();
    var vEl = document.getElementById('origin-verdict');
    var nEl = document.getElementById('origin-note');
    if (best){
      var nm = CNAME[best] ? CNAME[best][T()] : best;
      vEl.textContent = (FLAG[best]||'🏳️') + '  ' + nm;
      nEl.innerHTML = tr(
        'Souhlasí <b style="color:var(--accent)">' + bestN + '</b> z ' + total + ' hlasů. Odhaduju, že jsi z téhle země — i kdyby IP tvrdila něco jiného.',
        '<b style="color:var(--accent)">' + bestN + '</b> of ' + total + ' votes agree. My guess where you\'re from — even if your IP says otherwise.'
      );
    } else {
      vEl.textContent = '· · ·';
    }
  }

  function collectOrigin(){
    S.originReady = true;
    renderOrigin();
    detectAdblock(function(on){
      adblockOn = on;
      renderOrigin();
      if (on){
        detectRegionFilter(function(cc){ adblockRegion = cc; renderOrigin(); });
      } else {
        adblockRegion = null; renderOrigin();
      }
    });
  }

  // ===================== 06 · SVOLENÍ =====================
  function bindPerms(){
    var geo = document.getElementById('perm-geo');
    geo && geo.addEventListener('click', function(){
      var pr = document.getElementById('pr-geo');
      pr.textContent = tr('ptám se…', 'asking…');
      if (!navigator.geolocation){ pr.textContent = tr('nedostupné','unavailable'); return; }
      navigator.geolocation.getCurrentPosition(function(p){
        pr.classList.add('danger');
        var la = p.coords.latitude, lo = p.coords.longitude, acc = Math.round(p.coords.accuracy);
        pr.textContent = la.toFixed(5) + ', ' + lo.toFixed(5) + '  ±' + acc + 'm';
        S.precise = { lat: la, lon: lo, acc: acc, address: null };
        var box = document.getElementById('geo-precise');
        var f = document.getElementById('geo-precise-map');
        var lnk = document.getElementById('geo-precise-link');
        var addr = document.getElementById('geo-precise-addr');
        if (f) f.src = osmEmbed(la, lo, 0.004);   // uličková úroveň
        if (lnk) lnk.href = osmLink(la, lo, 17);
        if (addr) addr.textContent = tr('zjišťuji adresu…', 'looking up address…');
        if (box) box.hidden = false;
        if (S.dossierReady) renderDossier();   // spis hned na GPS (bez čekání na adresu)
        reverseGeocode(la, lo);                 // …a doplň celou adresu, až dorazí
      }, function(){ pr.textContent = tr('odmítnuto','denied'); }, { enableHighAccuracy: true, timeout: 10000 });
    });

    var cam = document.getElementById('perm-cam');
    cam && cam.addEventListener('click', function(){
      var pr = document.getElementById('pr-cam');
      pr.textContent = tr('ptám se…', 'asking…');
      if (!navigator.mediaDevices){ pr.textContent = tr('nedostupné','unavailable'); return; }
      navigator.mediaDevices.getUserMedia({ video: true }).then(function(stream){
        var track = stream.getVideoTracks()[0];
        var st = track.getSettings ? track.getSettings() : {};
        pr.classList.add('danger');
        pr.textContent = (track.label || tr('kamera','camera')) + (st.width ? '  ' + st.width + '×' + st.height : '');
        stream.getTracks().forEach(function(t){ t.stop(); });
      }).catch(function(){ pr.textContent = tr('odmítnuto','denied'); });
    });

    var mic = document.getElementById('perm-mic');
    mic && mic.addEventListener('click', function(){
      var pr = document.getElementById('pr-mic');
      pr.textContent = tr('ptám se…', 'asking…');
      if (!navigator.mediaDevices){ pr.textContent = tr('nedostupné','unavailable'); return; }
      navigator.mediaDevices.getUserMedia({ audio: true }).then(function(stream){
        var AC = window.AudioContext || window.webkitAudioContext;
        var ac = new AC(); var src = ac.createMediaStreamSource(stream);
        var an = ac.createAnalyser(); an.fftSize = 256; src.connect(an);
        var buf = new Uint8Array(an.frequencyBinCount);
        pr.classList.add('danger');
        var t0 = Date.now();
        (function tick(){
          an.getByteFrequencyData(buf);
          var sum = 0; for (var i=0;i<buf.length;i++) sum += buf[i];
          var lvl = Math.round(sum / buf.length);
          var bars = '█'.repeat(Math.min(20, Math.round(lvl/4)));
          pr.textContent = tr('hladina ', 'level ') + lvl + '  ' + bars;
          if (Date.now() - t0 < 8000) requestAnimationFrame(tick);
          else { stream.getTracks().forEach(function(t){t.stop();}); ac.close(); pr.textContent += tr('  (stop)','  (stop)'); }
        })();
      }).catch(function(){ pr.textContent = tr('odmítnuto','denied'); });
    });

    var bat = document.getElementById('perm-battery');
    bat && bat.addEventListener('click', function(){
      var pr = document.getElementById('pr-battery');
      if (!navigator.getBattery){ pr.textContent = tr('nedostupné (Safari/FF)','unavailable (Safari/FF)'); return; }
      navigator.getBattery().then(function(b){
        var lvl = (b && typeof b.level === 'number') ? b.level : NaN;
        if (isNaN(lvl)){ pr.textContent = tr('nešlo přečíst (nejspíš stolní PC)','couldn\'t read it (likely a desktop)'); return; }
        pr.classList.add('danger');
        pr.textContent = Math.round(lvl*100) + '%  ' + (b.charging ? tr('· nabíjí se','· charging') : tr('· z baterie','· on battery'));
      }).catch(function(){ pr.textContent = tr('nešlo přečíst','couldn\'t read it'); });
    });
  }

  // ===================== 06 · CHOVÁNÍ (živě) =====================
  // Posluchače navěsíme hned při načtení, ať se počítá od začátku.
  var beh = { mouse:0, dist:0, clicks:0, keys:0, scroll:0, away:0, start:0, lastX:null, lastY:null };
  function initBehavior(){
    S.behavior = beh; beh.start = Date.now();
    window.addEventListener('mousemove', function(e){
      beh.mouse++;
      if (beh.lastX != null){ var dx = e.clientX-beh.lastX, dy = e.clientY-beh.lastY; beh.dist += Math.sqrt(dx*dx+dy*dy); }
      beh.lastX = e.clientX; beh.lastY = e.clientY;
    }, { passive:true });
    window.addEventListener('click', function(){ beh.clicks++; }, { passive:true });
    window.addEventListener('keydown', function(){ beh.keys++; }, { passive:true });
    window.addEventListener('scroll', function(){
      var h = document.documentElement.scrollHeight - window.innerHeight;
      var p = h > 0 ? Math.round(window.scrollY / h * 100) : 0; if (p > beh.scroll) beh.scroll = p;
    }, { passive:true });
    document.addEventListener('visibilitychange', function(){ if (document.hidden) beh.away++; });
  }
  function renderBehavior(){
    var b = S.behavior; if (!b) return;
    set('b-time', Math.round((Date.now()-b.start)/1000) + ' s', 'hot');
    set('b-mouse', b.mouse + tr(' pohybů', ' moves'), b.mouse ? 'hot' : '');
    set('b-dist', Math.round(b.dist) + ' px', b.dist ? 'hot' : '');
    set('b-clicks', String(b.clicks));
    set('b-keys', String(b.keys), b.keys ? 'hot' : '');
    set('b-scroll', b.scroll + tr(' % stránky', ' % of the page'));
    set('b-away', b.away + (b.away ? tr('  · vím o tom', '  · I noticed') : ''), b.away ? 'danger' : '');
  }
  var behLoop = false;
  function collectBehavior(){
    if (behLoop) return; behLoop = true;
    renderBehavior();
    setInterval(renderBehavior, 500);
  }

  // ===================== FINÁLE · SPIS (dossier) =====================
  function setText(id, txt){ var el = document.getElementById(id); if (el) el.textContent = txt; }
  // Hrubý odhad entropie otisku → "jsi 1 z X".
  function trackBits(){
    var b = 10 + 4 + 4 + 3; // UA, obrazovka, timezone, jazyk (základ)
    if (S.fp){ if (S.fp.cv) b += 16; if (S.fp.wg) b += 10; if (S.fp.au) b += 6; b += Math.min((S.fp.fonts||[]).length, 20) * 0.6; }
    if (getGPU()) b += 5;
    if (navigator.hardwareConcurrency) b += 2;
    if (navigator.deviceMemory) b += 2;
    return Math.round(b);
  }
  function collectDossier(){
    S.dossierReady = true;
    if (!S.device) collectDevice();
    if (!S.browser) collectBrowser();
    if (!S.fp) collectFingerprint();
    if (!S.originReady) collectOrigin();
    collectMediaDevices();
    renderDossier();
  }
  function renderDossier(){
    setText('ds-code', (S.fp && S.fp.id) ? ('#' + S.fp.id) : '#········');
    var loc = '—';
    if (S.precise && (S.precise.address || S.precise.lat != null)){
      loc = (S.precise.address || (S.precise.lat.toFixed(5) + ', ' + S.precise.lon.toFixed(5))) + '  ·  GPS';
    } else if (S.whoami && S.whoami !== false && S.whoami.geo){
      var g = S.whoami.geo, cn = g.countryName ? g.countryName[T()] : g.country;
      loc = [g.city, cn].filter(Boolean).join(', ') || '—';
    } else if (S.originBest){ loc = CNAME[S.originBest] ? CNAME[S.originBest][T()] : S.originBest; }
    setText('ds-loc', loc);
    setText('ds-ip', (S.whoami && S.whoami !== false && S.whoami.ip) ? S.whoami.ip : tr('(jen na nasazeném webu)', '(only on deployed site)'));
    var gd = guessDevice();
    setText('ds-device', gd ? gd.name : guessOS());
    setText('ds-browser', guessBrowser() + ' · ' + guessEngine());
    setText('ds-fp', (S.fp && S.fp.id) ? S.fp.id : tr('počítám…', 'computing…'));
    var superTxt = '—';
    if (S.sc){ superTxt = S.sc.error ? tr('(jen na nasazeném webu)', '(only on deployed site)')
      : (S.sc.returning ? tr('ANO — poznán z cache', 'YES — recognized from cache') : tr('ID uloženo v cache', 'ID stored in cache')); }
    setText('ds-super', superTxt);

    var bits = trackBits();
    setText('ds-track', bits >= 20 ? tr('VYSOKÁ', 'HIGH') : bits >= 12 ? tr('STŘEDNÍ', 'MEDIUM') : tr('NÍZKÁ', 'LOW'));
    var oneIn = Math.pow(2, bits), nEl = document.getElementById('ds-track-note');
    if (nEl){
      if (oneIn > 8e9){
        nEl.textContent = tr('Z nasbíraných znaků poskládám otisk s ~' + bits + ' bity entropie — prakticky unikátní mezi všemi prohlížeči na světě.',
                             'The collected traits form a ~' + bits + '-bit fingerprint — practically unique among every browser on Earth.');
      } else {
        var x = Math.round(oneIn).toLocaleString();
        nEl.textContent = tr('Otisk má ~' + bits + ' bitů entropie — jsi zhruba 1 z ' + x + '.',
                             'The fingerprint carries ~' + bits + ' bits of entropy — you\'re roughly 1 in ' + x + '.');
      }
    }
  }

  // ===================== reveal při scrollu =====================
  function setupReveal(runners){
    var panels = document.querySelectorAll('[data-panel]');
    var io = new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        if (e.isIntersecting){
          e.target.classList.add('in');
          var run = e.target.getAttribute('data-run');
          if (run && runners[run] && !e.target.__ran){ e.target.__ran = true; runners[run](); }
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.25 });
    panels.forEach(function(p){ io.observe(p); });
  }

  // přiřaď "runners" k panelům podle pořadí
  // 0 Síť · 1 Zařízení · 2 Prohlížeč · 3 Otisk · 4 Původ · 5 Chování · 6 Svolení · 7 Retro · 8 Spis
  var cards = document.querySelectorAll('[data-panel]');
  if (cards[1]) cards[1].setAttribute('data-run','device');
  if (cards[2]) cards[2].setAttribute('data-run','browser');
  if (cards[3]) cards[3].setAttribute('data-run','fp');
  if (cards[4]) cards[4].setAttribute('data-run','origin');
  if (cards[5]) cards[5].setAttribute('data-run','behavior');
  if (cards[6]) cards[6].setAttribute('data-run','perms');
  if (cards[8]) cards[8].setAttribute('data-run','dossier');

  // Přerenderuj vše jazykově závislé z uloženého stavu (při přepnutí CZ/EN).
  function rerenderAll(){
    renderNet();
    renderWebRTC();
    if (heroDone && !heroTyping) renderHeroFinal();
    if (S.device) renderDevice();
    if (S.browser) renderBrowser();
    if (S.fp) renderFpRows();
    if (S.sc) renderSupercookie();
    if (S.originReady) renderOrigin();
    if (S.behavior) renderBehavior();
    if (S.dossierReady) renderDossier();
  }

  function start(){
    initBehavior();
    setupReveal({ device: collectDevice, browser: collectBrowser, fp: collectFingerprint,
      origin: collectOrigin, behavior: collectBehavior, perms: bindPerms, dossier: collectDossier });
    window.onLangChange = rerenderAll; // Layout volá při přepnutí vlajky
  }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', start);
  else start();
})();
</script>

</Layout>
