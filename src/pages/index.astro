  // ===================== 05 · PŮVOD (triangulace) =====================
  // Spolehlivý "bait": element s reklamními třídami. Pokud ho adblock schová
  // (výška 0 / display none), je aktivní. Plně lokální, nic neodchází.
  function detectAdblock(cb){
    var bait = document.createElement('div');
    bait.className = 'ad ads adsbox ad-banner ad-placement pub_300x250 textads banner_ad sponsored';
    bait.style.cssText = 'position:absolute!important;left:-9999px;top:-9999px;width:300px;height:250px;';
    bait.innerHTML = '&nbsp;';
    document.body.appendChild(bait);
    setTimeout(function(){
      var blocked = !bait.offsetHeight || !bait.offsetParent ||
        bait.clientHeight === 0 || getComputedStyle(bait).display === 'none' ||
        getComputedStyle(bait).visibility === 'hidden';
      try { document.body.removeChild(bait); } catch(_){}
      cb(blocked);
    }, 130);
  }

  // Best-effort detekce regionálního filtru přes cosmetic baiting. Selektory
  // se mění → je to orientační (a po nasazení doladíme reálné baity).
  // Mapuje "kosmetické pravidlo, které řeší hlavně daný regionální seznam" → země.
  var REGION_BAITS = [
    { country: 'CZ', sel: 'div', cls: 'reklama reklamni-banner inzerce' },
    { country: 'PL', sel: 'div', cls: 'reklama-box rekl' },
  ];
  function detectRegionFilter(cb){
    var nodes = REGION_BAITS.map(function(b){
      var el = document.createElement(b.sel);
      el.className = b.cls;
      el.style.cssText = 'position:absolute!important;left:-9999px;top:-9999px;width:280px;height:90px;';
      el.innerHTML = '&nbsp;';
      document.body.appendChild(el);
      return el;
    });
    setTimeout(function(){
      var hit = null;
      for (var i = 0; i < nodes.length; i++){
        var el = nodes[i];
        var blocked = !el.offsetHeight || !el.offsetParent || getComputedStyle(el).display === 'none';
        if (blocked && !hit) hit = REGION_BAITS[i].country;
      }
      nodes.forEach(function(n){ try { document.body.removeChild(n); } catch(_){} });
      cb(hit);
    }, 150);
  }

  var FLAG = { CZ:'🇨🇿', SK:'🇸🇰', PL:'🇵🇱', DE:'🇩🇪', AT:'🇦🇹', US:'🇺🇸', GB:'🇬🇧' };
  var CNAME = { CZ:{cs:'Česko',en:'Czechia'}, SK:{cs:'Slovensko',en:'Slovakia'},
    PL:{cs:'Polsko',en:'Poland'}, DE:{cs:'Německo',en:'Germany'}, AT:{cs:'Rakousko',en:'Austria'},
    US:{cs:'USA',en:'USA'}, GB:{cs:'Velká Británie',en:'United Kingdom'} };
  function flag(cc){ return cc ? (FLAG[cc] || '🏳️') + ' ' + cc : ''; }

  function tzCountry(tz){
    if (!tz) return null;
    var map = { 'Europe/Prague':'CZ','Europe/Bratislava':'SK','Europe/Warsaw':'PL',
      'Europe/Berlin':'DE','Europe/Vienna':'AT','Europe/London':'GB',
      'America/New_York':'US','America/Los_Angeles':'US','America/Chicago':'US' };
    return map[tz] || null;
  }
  function langCountry(l){
    if (!l) return null; l = l.toLowerCase();
    if (l.indexOf('-') > 0) return l.split('-')[1].toUpperCase();
    var map = { cs:'CZ', sk:'SK', pl:'PL', de:'DE', en:null };
