---
import Layout from '../layouts/Layout.astro';

// "I Google You" — jedna dlouhá scrollovací stránka. Hero udělá dramatický
// "scan", pak se při scrollu odhalují panely "dossieru": síť, zařízení,
// prohlížeč, otisk (fingerprint) a volitelná svolení. Nic se neukládá ani
// neodesílá — vše počítá prohlížeč u tebe, serverová data jen čte /api/whoami.

// Helper: jeden řádek "klíč → hodnota" s místem (id), které doplní JS.
const Row = (id: string, kCs: string, kEn: string) => ({ id, kCs, kEn });

const netRows = [
  Row('ip', 'IP adresa', 'IP address'),
  Row('ipver', 'Verze IP', 'IP version'),
  Row('city', 'Město', 'City'),
  Row('region', 'Region', 'Region'),
  Row('country', 'Země', 'Country'),
  Row('isp', 'Operátor / ASN', 'ISP / ASN'),
  Row('colo', 'Prošel jsi přes', 'You routed via'),
  Row('proto', 'Protokol', 'Protocol'),
  Row('tls', 'TLS', 'TLS'),
  Row('rtt', 'Latence k uzlu', 'Latency to node'),
  Row('rtc-local', 'Lokální IP (WebRTC)', 'Local IP (WebRTC)'),
  Row('rtc-public', 'Veřejná IP (STUN)', 'Public IP (STUN)'),
];
// Signály pro triangulaci původu (panel 05). Texty řádků doplní JS.
const originRows = [
  Row('o-ip', 'Podle IP', 'By IP'),
  Row('o-tz', 'Časové pásmo', 'Time zone'),
  Row('o-lang', 'Jazyk prohlížeče', 'Browser language'),
  Row('o-locale', 'Formát čísel', 'Number format'),
  Row('o-adblock', 'Adblock', 'Adblock'),
  Row('o-adregion', 'Regionální filtr', 'Regional filter'),
];
const behaviorRows = [
  Row('b-time', 'Čas na stránce', 'Time on page'),
  Row('b-mouse', 'Pohyby myši', 'Mouse moves'),
  Row('b-dist', 'Ujetá vzdálenost', 'Distance travelled'),
  Row('b-clicks', 'Kliknutí', 'Clicks'),
  Row('b-keys', 'Stisky kláves', 'Keystrokes'),
  Row('b-scroll', 'Kam jsi doscrolloval', 'How far you scrolled'),
  Row('b-away', 'Kolikrát ses koukl jinam', 'Times you looked away'),
];
const deviceRows = [
  Row('os', 'Systém', 'OS'),
  Row('platform', 'Platforma', 'Platform'),
  Row('cores', 'Jádra CPU', 'CPU cores'),
  Row('ram', 'Paměť (min.)', 'Memory (min.)'),
  Row('touch', 'Dotykové body', 'Touch points'),
  Row('screen', 'Obrazovka', 'Screen'),
  Row('viewport', 'Okno', 'Viewport'),
  Row('dpr', 'Pixel ratio', 'Pixel ratio'),
  Row('depth', 'Barevná hloubka', 'Color depth'),
  Row('gpu', 'Grafika (GPU)', 'Graphics (GPU)'),
  Row('device-guess', 'Odhad zařízení', 'Best-guess device'),
  Row('media-cam', 'Připojené kamery', 'Cameras attached'),
  Row('media-mic', 'Připojené mikrofony', 'Mics attached'),
];
const browserRows = [
  Row('browser', 'Prohlížeč', 'Browser'),
  Row('engine', 'Jádro', 'Engine'),
  Row('langs', 'Jazyky', 'Languages'),
  Row('tz', 'Časové pásmo', 'Time zone'),
  Row('localtime', 'Tvůj čas', 'Your time'),
  Row('locale', 'Formát čísel', 'Number format'),
  Row('dnt', 'Do Not Track', 'Do Not Track'),
  Row('cookies', 'Cookies', 'Cookies'),
  Row('ua', 'User-Agent', 'User-Agent'),
];
const fpRows = [
  Row('fp-canvas', 'Canvas otisk', 'Canvas hash'),
  Row('fp-webgl', 'WebGL otisk', 'WebGL hash'),
  Row('fp-audio', 'Audio otisk', 'Audio hash'),
  Row('fp-fonts', 'Detekované fonty', 'Detected fonts'),
  Row('fp-software', 'Software podle fontů', 'Software from fonts'),
];
---
<Layout
  titleCs="I Google You — vidím tě"
  titleEn="I Google You — I can see you">

<style is:global>
  /* ---------- Layout sekcí ---------- */
  main { width: 100%; }
  .wrap { width: min(880px, 92vw); margin: 0 auto; }

  /* ---------- HERO ---------- */
  .hero {
    min-height: 100svh; display: flex; flex-direction: column;
    align-items: center; justify-content: center; text-align: center;
    padding: 80px 20px 40px; position: relative;
  }
  .eyebrow {
    font-family: var(--mono); font-size: 12px; letter-spacing: .32em;
    text-transform: uppercase; color: var(--accent); margin-bottom: 26px;
    display: inline-flex; align-items: center; gap: 10px;
  }
  .eyebrow .dot {
    width: 7px; height: 7px; border-radius: 50%; background: var(--accent);
    box-shadow: 0 0 10px var(--accent); animation: pulse 1.6s ease-in-out infinite;
  }
  @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.35;transform:scale(.7)} }

  .hero h1 {
    font-size: clamp(40px, 9vw, 92px); line-height: .98; font-weight: 800;
    letter-spacing: -0.035em; margin: 0; max-width: 14ch;
    background: linear-gradient(180deg, #fff 30%, #9fb0bd 100%);
    -webkit-background-clip: text; background-clip: text; color: transparent;
  }
  .hero h1 .hl { color: var(--danger); -webkit-text-fill-color: var(--danger); }

  .scanline {
    font-family: var(--mono); font-size: clamp(14px, 2.4vw, 19px); color: var(--ink-dim);
    margin: 30px 0 0; min-height: 1.6em;
  }
  .scanline b { color: var(--accent); font-weight: 600; }
  .scanline .cursor {
    display: inline-block; width: .6ch; background: var(--accent); margin-left: 1px;
    animation: blink 1s step-end infinite;
  }
  @keyframes blink { 50% { opacity: 0; } }

  .scrollcue {
    position: absolute; bottom: 26px; left: 50%; transform: translateX(-50%);
    font-family: var(--mono); font-size: 12px; letter-spacing: .2em; text-transform: uppercase;
    color: var(--accent); display: flex; flex-direction: column; align-items: center; gap: 12px;
    opacity: 0; transition: opacity .6s; animation: floaty 1.8s ease-in-out infinite;
    text-shadow: 0 0 18px rgba(56,232,200,0.5);
  }
  .scrollcue.show { opacity: 1; }
  .scrollcue .arrow {
    display: flex; align-items: center; justify-content: center;
    width: 34px; height: 34px; border-radius: 50%; font-size: 18px;
    border: 1px solid var(--accent); color: var(--accent);
    box-shadow: 0 0 20px rgba(56,232,200,0.35); background: rgba(56,232,200,0.06);
  }
  @keyframes floaty { 0%,100%{transform:translate(-50%,0)} 50%{transform:translate(-50%,8px)} }

  /* ---------- PANELY (dossier) ---------- */
  .panel { padding: 60px 0; }
  .panel-card {
    border: 1px solid var(--panel-border); border-radius: 18px;
    background:
      linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.008));
    overflow: hidden; position: relative;
    opacity: 0; transform: translateY(34px); filter: blur(6px);
    transition: opacity .7s ease, transform .7s cubic-bezier(.2,.7,.2,1), filter .7s;
  }
  .panel-card.in { opacity: 1; transform: none; filter: none; }
  .panel-card::before { /* horní accent linka */
    content: ""; position: absolute; top: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, transparent, var(--accent-dim), transparent);
  }

  .panel-head {
    display: flex; align-items: center; gap: 14px; padding: 20px 24px;
    border-bottom: 1px solid var(--panel-border);
  }
  .panel-num {
    font-family: var(--mono); font-size: 12px; color: var(--accent);
    border: 1px solid var(--accent-dim); border-radius: 6px; padding: 3px 7px;
  }
  .panel-title { font-size: 17px; font-weight: 700; letter-spacing: -0.01em; margin: 0; }
  .panel-sub { font-size: 13px; color: var(--ink-dim); margin-left: auto; text-align: right; }

  .rows { display: grid; grid-template-columns: 1fr; }
  .row {
    display: grid; grid-template-columns: minmax(120px, 38%) 1fr; gap: 16px;
    padding: 13px 24px; border-bottom: 1px solid rgba(255,255,255,0.045);
    font-size: 14px; align-items: baseline;
  }
  .row:last-child { border-bottom: none; }
  .row .k { color: var(--ink-dim); }
  .row .v {
    font-family: var(--mono); color: var(--ink); word-break: break-word;
    opacity: 0; transform: translateY(4px); transition: opacity .4s, transform .4s;
  }
  .panel-card.in .row .v { opacity: 1; transform: none; }
  .row .v.pending { color: var(--ink-faint); }
  .row .v.hot { color: var(--amber); }
  .row .v.danger { color: var(--danger); }
  .row .v small { color: var(--ink-faint); font-size: 12px; }

  /* Intro každého panelu */
  .lead { font-size: 15px; line-height: 1.65; color: var(--ink-dim); margin: 0 0 26px; }
  .lead b { color: var(--ink); font-weight: 600; }

  /* ---------- Fingerprint verdikt ---------- */
  .fp-verdict {
    margin-top: 18px; padding: 24px; border-radius: 16px;
    border: 1px solid rgba(255,92,108,0.3); background: rgba(255,92,108,0.06);
    text-align: center;
  }
  .fp-id {
    font-family: var(--mono); font-size: clamp(20px, 5vw, 34px); font-weight: 700;
    color: var(--danger); letter-spacing: .04em; word-break: break-all;
  }
  .fp-verdict p { color: var(--ink-dim); font-size: 14px; margin: 14px 0 0; line-height: 1.6; }
  .incognito {
    display: inline-flex; align-items: center; gap: 10px; margin: 18px auto 0;
    padding: 11px 20px; border-radius: 999px;
    border: 1px solid rgba(56,232,200,0.4); background: rgba(56,232,200,0.08);
    font-family: var(--mono); font-size: 14px; font-weight: 600; color: var(--accent);
    box-shadow: 0 0 26px rgba(56,232,200,0.12);
  }
  .incognito .ic { font-size: 17px; filter: grayscale(1) brightness(1.6); }
  .incognito-try { color: var(--ink-faint) !important; font-size: 12.5px !important; margin-top: 12px !important; }
  .sc-box {
    margin-top: 14px; padding: 22px; border-radius: 16px; text-align: center;
    border: 1px solid rgba(255,184,77,0.3); background: rgba(255,184,77,0.06);
  }
  .sc-tag { font-family: var(--mono); font-size: 12px; letter-spacing: .06em; color: var(--amber); margin-bottom: 12px; }
  .sc-box .fp-id { color: var(--amber); font-size: clamp(18px, 4.5vw, 28px); }
  .sc-box .fp-id.danger { color: var(--danger); }
  .sc-box p { color: var(--ink-dim); font-size: 14px; margin: 12px 0 0; line-height: 1.6; }
  .sc-box p b { color: var(--ink); }
  .fp-bar { height: 4px; border-radius: 999px; background: rgba(255,255,255,0.07); overflow: hidden; margin: 0 0 18px; }
  .fp-bar i { display: block; height: 100%; width: 0; background: linear-gradient(90deg, var(--accent), var(--danger)); transition: width .5s ease; }

  /* ---------- Volitelná svolení ---------- */
  .perm-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(190px,1fr)); gap: 12px; }
  .perm {
    text-align: left; border: 1px solid var(--panel-border); border-radius: 14px;
    background: rgba(255,255,255,0.02); padding: 16px; cursor: pointer; color: var(--ink);
    font-family: inherit; transition: border-color .15s, background .15s, transform .05s;
  }
  .perm:hover { border-color: var(--accent-dim); background: rgba(56,232,200,0.05); }
  .perm:active { transform: scale(.98); }
  .perm .pi { font-size: 22px; }
  .perm .pt { font-weight: 700; font-size: 14px; margin: 8px 0 4px; }
  .perm .pd { font-size: 12.5px; color: var(--ink-dim); line-height: 1.5; }
  .perm .pr { font-family: var(--mono); font-size: 12.5px; color: var(--accent); margin-top: 10px; min-height: 1.2em; word-break: break-word; }
  .perm .pr.danger { color: var(--danger); }

  /* ---------- Geo reticle (mapa podle IP) ---------- */
  .geo-wrap { padding: 8px 24px 22px; }
  .geo-stack { position: relative; border-radius: 12px; overflow: hidden;
    border: 1px solid var(--panel-border); background: #05070a; aspect-ratio: 760 / 240; }
  #geo-map-frame { position: absolute; inset: 0; width: 100%; height: 100%; border: 0;
    pointer-events: none; filter: grayscale(.35) brightness(.62) contrast(1.05); }
  .geo-tint { position: absolute; inset: 0; pointer-events: none;
    background: radial-gradient(circle at 50% 50%, rgba(56,232,200,0.12), transparent 55%),
      linear-gradient(180deg, rgba(5,7,10,0.35), rgba(5,7,10,0.55)); }
  #geo-map { position: absolute; inset: 0; width: 100%; height: 100%; display: block; pointer-events: none; }
  .geo-cap { display: flex; justify-content: space-between; align-items: center; gap: 12px;
    margin-top: 10px; font-family: var(--mono); font-size: 12.5px; color: var(--ink-dim); }
  .geo-cap a { color: var(--accent); text-decoration: none; border-bottom: 1px solid var(--accent-dim); white-space: nowrap; }
  .geo-cap a:hover { color: #fff; }

  /* ---------- Přesná GPS mapa (panel Svolení) ---------- */
  #geo-precise { margin-top: 16px; }
  #geo-precise-map { width: 100%; height: 260px; border: 1px solid var(--panel-border);
    border-radius: 14px; filter: grayscale(.25) brightness(.72) contrast(1.05); }
  .geo-addr { margin-top: 10px; font-family: var(--mono); font-size: 13px; color: var(--danger);
    line-height: 1.5; word-break: break-word; }

  /* ---------- Retro ---------- */
  .retro-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px,1fr)); gap: 10px; }
  .retro {
    border: 1px solid var(--panel-border); border-radius: 12px; padding: 14px;
    background: rgba(255,255,255,0.015);
  }
  .retro .rn { font-weight: 700; font-size: 14px; }
  .retro .rs { font-family: var(--mono); font-size: 11px; color: var(--danger); text-transform: uppercase; letter-spacing: .08em; }
  .retro .rd { font-size: 12.5px; color: var(--ink-dim); margin-top: 6px; line-height: 1.5; }

  /* ---------- Outro ---------- */
  .outro { text-align: center; padding: 90px 20px 70px; }
  .outro h2 { font-size: clamp(26px, 5vw, 40px); font-weight: 800; letter-spacing: -0.02em; margin: 0 0 18px; }
  .outro p { color: var(--ink-dim); font-size: 15px; line-height: 1.7; max-width: 60ch; margin: 0 auto 14px; }
  .privacy {
    display: inline-flex; align-items: center; gap: 9px; margin-top: 14px; padding: 10px 18px;
    border: 1px solid var(--accent-dim); border-radius: 999px; color: var(--accent);
    font-family: var(--mono); font-size: 13px;
  }
  .footer-link { margin-top: 34px; display: flex; gap: 22px; justify-content: center; }
  .footer-link a { color: var(--ink-dim); text-decoration: none; font-size: 13px; border-bottom: 1px solid var(--ink-faint); }
  .footer-link a:hover { color: var(--accent); border-color: var(--accent); }

  .section-label {
    font-family: var(--mono); font-size: 12px; letter-spacing: .26em; text-transform: uppercase;
    color: var(--accent); margin: 0 0 16px; display: block;
  }

  /* ---------- Finální spis (dossier) ---------- */
  .dossier {
    width: min(680px, 100%); margin: 30px auto 10px; text-align: left;
    border: 1px solid rgba(255,92,108,0.28); border-radius: 16px; overflow: hidden;
    background: linear-gradient(180deg, rgba(255,92,108,0.05), rgba(255,255,255,0.008));
    opacity: 0; transform: translateY(28px) scale(.99); filter: blur(6px);
    transition: opacity .8s ease, transform .8s cubic-bezier(.2,.7,.2,1), filter .8s;
  }
  .dossier.in { opacity: 1; transform: none; filter: none; }
  .dossier-head {
    display: flex; align-items: center; gap: 12px; padding: 14px 20px;
    border-bottom: 1px solid rgba(255,92,108,0.2); font-family: var(--mono); font-size: 12px;
    letter-spacing: .14em; color: var(--ink-dim);
  }
  .ds-rec { color: var(--danger); font-weight: 700; animation: pulse 1.6s ease-in-out infinite; }
  .ds-title { color: var(--ink); }
  .ds-code { margin-left: auto; color: var(--danger); }
  .dossier-grid { padding: 6px 20px; }
  .ds-row { display: grid; grid-template-columns: 40% 1fr; gap: 12px; padding: 11px 0;
    border-bottom: 1px solid rgba(255,255,255,0.045); font-size: 14px; align-items: baseline; }
  .ds-row:last-child { border-bottom: none; }
  .ds-k { color: var(--ink-dim); font-size: 12.5px; text-transform: uppercase; letter-spacing: .04em; }
  .ds-v { font-family: var(--mono); color: var(--ink); word-break: break-word; }
  .ds-track { padding: 20px; text-align: center; border-top: 1px solid rgba(255,92,108,0.2);
    background: rgba(255,92,108,0.06); }
  .ds-track-label { font-family: var(--mono); font-size: 11px; letter-spacing: .22em; color: var(--ink-dim); }
  .ds-track-val { font-family: var(--mono); font-size: clamp(22px, 5vw, 34px); font-weight: 800;
    color: var(--danger); margin: 8px 0 6px; }
  .ds-track-note { color: var(--ink-dim); font-size: 13px; line-height: 1.55; max-width: 52ch; margin: 0 auto; }
</style>

<main>
  <noscript>
    <div style="max-width:680px;margin:80px auto;padding:0 20px;text-align:center;font-family:var(--sans);">
      <p style="font-size:20px;color:var(--ink);font-weight:700;">
        <span class="cs">igy.cz běží na JavaScriptu.</span>
        <span class="en">igy.cz runs on JavaScript.</span>
      </p>
      <p style="color:var(--ink-dim);line-height:1.6;">
        <span class="cs">Máš ho vypnutý — a to je paradoxně nejlepší obrana proti tomu, co tenhle web ukazuje. Zapni ho, jestli chceš vidět, co o tobě prohlížeč prozradí.</span>
        <span class="en">You've turned it off — which is ironically the best defense against what this site demonstrates. Enable it to see what your browser reveals about you.</span>
      </p>
    </div>
  </noscript>

  <!-- ============ HERO ============ -->
  <section class="hero">
    <span class="eyebrow"><span class="dot"></span> igy.cz · I Google You</span>
    <h1>
      <span class="cs">Myslíš, že jsi tu <span class="hl">anonymně?</span></span>
      <span class="en">Think you're here <span class="hl">anonymously?</span></span>
    </h1>
    <p class="scanline" id="scanline"><span class="cursor">&nbsp;</span></p>
    <div class="scrollcue" id="scrollcue">
      <span class="cs">scrolluj — uvidíš, co o tobě vím</span>
      <span class="en">scroll — see what I know about you</span>
      <span class="arrow">↓</span>
    </div>
  </section>

  <!-- ============ 01 · SÍŤ ============ -->
  <section class="panel"><div class="wrap"><div class="panel-card" data-panel>
    <div class="panel-head">
      <span class="panel-num">01</span>
      <h2 class="panel-title"><span class="cs">Síť</span><span class="en">Network</span></h2>
      <span class="panel-sub"><span class="cs">co vidí server</span><span class="en">what the server sees</span></span>
    </div>
    <div class="rows">
      {netRows.map((r) => (
        <div class="row">
          <span class="k"><span class="cs">{r.kCs}</span><span class="en">{r.kEn}</span></span>
          <span class="v pending" id={`v-${r.id}`}>…</span>
        </div>
      ))}
    </div>
    <div class="geo-wrap" id="geo-wrap" hidden>
      <div class="geo-stack">
        <iframe id="geo-map-frame" title="map" loading="lazy" referrerpolicy="no-referrer"></iframe>
        <div class="geo-tint"></div>
        <canvas id="geo-map" width="760" height="240"></canvas>
      </div>
      <div class="geo-cap">
        <span id="geo-cap-txt"></span>
        <a id="geo-osm" href="#" target="_blank" rel="noopener noreferrer">
          <span class="cs">otevřít v mapě →</span><span class="en">open in map →</span>
        </a>
      </div>
    </div>
  </div></div></section>

  <!-- ============ 02 · ZAŘÍZENÍ ============ -->
  <section class="panel"><div class="wrap"><div class="panel-card" data-panel>
    <div class="panel-head">
      <span class="panel-num">02</span>
      <h2 class="panel-title"><span class="cs">Zařízení</span><span class="en">Device</span></h2>
      <span class="panel-sub"><span class="cs">tvůj hardware</span><span class="en">your hardware</span></span>
    </div>
    <div class="rows">
      {deviceRows.map((r) => (
        <div class="row">
          <span class="k"><span class="cs">{r.kCs}</span><span class="en">{r.kEn}</span></span>
          <span class="v pending" id={`v-${r.id}`}>…</span>
        </div>
      ))}
    </div>
  </div></div></section>

  <!-- ============ 03 · PROHLÍŽEČ ============ -->
  <section class="panel"><div class="wrap"><div class="panel-card" data-panel>
    <div class="panel-head">
      <span class="panel-num">03</span>
      <h2 class="panel-title"><span class="cs">Prohlížeč</span><span class="en">Browser</span></h2>
      <span class="panel-sub"><span class="cs">software a nastavení</span><span class="en">software & settings</span></span>
    </div>
    <div class="rows">
      {browserRows.map((r) => (
        <div class="row">
          <span class="k"><span class="cs">{r.kCs}</span><span class="en">{r.kEn}</span></span>
          <span class="v pending" id={`v-${r.id}`}>…</span>
        </div>
      ))}
    </div>
  </div></div></section>

  <!-- ============ 04 · OTISK ============ -->
  <section class="panel"><div class="wrap"><div class="panel-card" data-panel>
    <div class="panel-head">
      <span class="panel-num">04</span>
      <h2 class="panel-title"><span class="cs">Otisk</span><span class="en">Fingerprint</span></h2>
      <span class="panel-sub"><span class="cs">tiché stopy</span><span class="en">silent traces</span></span>
    </div>
    <div style="padding: 20px 24px 4px;">
      <p class="lead" style="margin-bottom:18px;">
        <span class="cs">Tohle nepotřebuje cookies ani přihlášení. Tvůj prohlížeč kreslí grafiku
        a přehrává zvuk nepatrně jinak než kterýkoli jiný — z těch rozdílů jde složit
        <b>skoro unikátní otisk</b>, který tě pozná i v anonymním okně.</span>
        <span class="en">No cookies, no login. Your browser draws graphics and plays audio
        slightly differently from every other one — those differences combine into an
        <b>almost-unique fingerprint</b> that recognizes you even in incognito.</span>
      </p>
    </div>
    <div class="rows">
