<script is:inline>
(function(){
  'use strict';
  var T = function(){ return window.__lang === 'en' ? 'en' : 'cs'; };
  function tr(cs, en){ return T() === 'en' ? en : cs; }
  function reduced(){ try { return window.matchMedia && matchMedia('(prefers-reduced-motion: reduce)').matches; } catch(e){ return false; } }
  function esc(s){ return String(s).replace(/[&<>"]/g, function(c){ return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c]; }); }

  // Uložený "surový" stav, aby šlo vše přerenderovat při přepnutí jazyka
  // (jinak by JS-doplňované hodnoty zůstaly v původním jazyce).
  var S = { whoami:null, hero:null, device:false, browser:false, webrtc:null,
            fp:null, sc:null, adblockOn:null, adblockRegion:null, originReady:false };

  // --- helper pro vyplnění řádků (reset tříd → korektní i při re-renderu) ---
  function set(id, val, cls){
    var el = document.getElementById('v-' + id);
    if (!el) return;
    el.classList.remove('pending', 'hot', 'danger');
    if (cls) el.classList.add(cls);
    el.textContent = (val === null || val === undefined || val === '') ? '—' : val;
  }

  // ===================== 01 · SÍŤ (server) =====================
  fetch('/api/whoami', { cache: 'no-store' }).then(function(r){ return r.ok ? r.json() : Promise.reject(); }).then(function(d){
    S.whoami = d;
    window.__whoami = d;            // sdílíme pro triangulaci původu (panel 05)
    renderNet();
    revealHero(d);
    if (S.originReady) renderOrigin(); // doplň IP-zemi do triangulace
    if (S.dossierReady) renderDossier();
  }).catch(function(){
    S.whoami = false;
    renderNet();
    revealHero(null);
    if (S.originReady) renderOrigin();
    if (S.dossierReady) renderDossier();
  });

  function renderNet(){
    var d = S.whoami;
    if (d == null) return;          // ještě neproběhlo → řádky zůstávají "…"
    if (d === false){
      ['ip','ipver','city','region','country','isp','colo','proto','tls','rtt'].forEach(function(id){
        set(id, tr('(jen na nasazeném webu)', '(only on deployed site)'));
      });
      return;
    }
    set('ip', d.ip, 'hot');
    set('ipver', d.ipVersion ? ('IPv' + d.ipVersion) : null);
    set('city', d.geo.city);
    set('region', d.geo.region);
    var cn = d.geo.countryName ? d.geo.countryName[T()] : d.geo.country;
    set('country', cn ? (cn + (d.geo.isEU ? ' · EU' : '')) : d.geo.country);
    set('isp', d.network.asOrganization ? (d.network.asOrganization + (d.network.asn ? '  ·  AS' + d.network.asn : '')) : (d.network.asn ? 'AS' + d.network.asn : null), 'hot');
    set('colo', d.network.colo ? (d.network.colo + tr('  (uzel Cloudflare)', '  (Cloudflare node)')) : null);
    set('proto', d.network.httpProtocol);
    set('tls', d.tls.version ? (d.tls.version + (d.tls.cipher ? '  ·  ' + d.tls.cipher : '')) : null);
    set('rtt', (d.tls.clientTcpRtt != null) ? (d.tls.clientTcpRtt + ' ms') : null);
    renderGeoMap();
  }

  // OpenStreetMap helpers (reálná mapa jako podklad + proklik).
  function osmEmbed(la, lo, d){ d = d || 0.02; var bbox = (lo-d)+','+(la-d)+','+(lo+d)+','+(la+d);
    return 'https://www.openstreetmap.org/export/embed.html?bbox=' + encodeURIComponent(bbox) + '&layer=mapnik&marker=' + encodeURIComponent(la + ',' + lo); }
  function osmLink(la, lo, z){ z = z || 14; return 'https://www.openstreetmap.org/?mlat=' + la + '&mlon=' + lo + '#map=' + z + '/' + la + '/' + lo; }

  // Reverzní geokódování přes OpenStreetMap Nominatim (zdarma, bez klíče) →
  // celá adresa z GPS souřadnic. Uloží do S.precise.address a překreslí spis.
  function reverseGeocode(la, lo){
    var url = 'https://nominatim.openstreetmap.org/reverse?format=json&addressdetails=1&zoom=18&lat=' + la + '&lon=' + lo;
    fetch(url, { headers: { 'Accept': 'application/json' } })
      .then(function(r){ return r.ok ? r.json() : Promise.reject(); })
      .then(function(d){
        var addr = (d && d.display_name) ? d.display_name : null;
        if (S.precise) S.precise.address = addr;
        var el = document.getElementById('geo-precise-addr');
        if (el) el.textContent = addr || tr('adresu se nepodařilo zjistit', 'address lookup failed');
        if (S.dossierReady) renderDossier();
      })
      .catch(function(){
        var el = document.getElementById('geo-precise-addr');
        if (el) el.textContent = tr('adresu se nepodařilo zjistit', 'address lookup failed');
      });
  }

  // Mapový "reticle" podle IP: reálná (ztlumená) mapa jako podklad + zaměřovač
  // nakreslený přes ni na průhledném canvasu.
  var geoMapStarted = false;
  function renderGeoMap(){
    var d = S.whoami; if (!d || d === false) return;
    var lat = d.geo.latitude, lon = d.geo.longitude;
    if (lat == null || lon == null) return;
    var wrap = document.getElementById('geo-wrap'); if (!wrap) return;
    wrap.hidden = false;
    var city = d.geo.city || (d.geo.countryName ? d.geo.countryName[T()] : d.geo.country) || '';
    var cap = document.getElementById('geo-cap-txt');
    if (cap) cap.textContent = (city ? city + '  ·  ' : '') + (+lat).toFixed(4) + ', ' + (+lon).toFixed(4);
    var osm = document.getElementById('geo-osm');
    if (osm) osm.href = osmLink(lat, lon, 12);
    var frameEl = document.getElementById('geo-map-frame');
    if (frameEl && !frameEl.src) frameEl.src = osmEmbed(+lat, +lon, 0.06);

    var canvas = document.getElementById('geo-map'); if (!canvas) return;
    var ctx = canvas.getContext('2d'); if (!ctx) return;
    var dpr = Math.min(window.devicePixelRatio || 1, 2);
    var W = 760, H = 240;
    canvas.width = W * dpr; canvas.height = H * dpr;
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    var cx = W / 2, cy = H / 2;

    function frame(t){
      ctx.clearRect(0, 0, W, H);   // průhledné → prosvítá mapa pod canvasem
      // pulzující kruhy
      var phase = (t % 2600) / 2600;
      for (var k = 0; k < 3; k++){
        var p = (phase + k / 3) % 1;
        ctx.beginPath(); ctx.arc(cx, cy, 20 + p * 96, 0, Math.PI * 2);
        ctx.strokeStyle = 'rgba(56,232,200,' + (0.5 * (1 - p)) + ')'; ctx.lineWidth = 1.5; ctx.stroke();
      }
      // kříž
      ctx.strokeStyle = 'rgba(56,232,200,0.6)'; ctx.lineWidth = 1;
      ctx.beginPath(); ctx.moveTo(cx - 130, cy); ctx.lineTo(cx + 130, cy);
      ctx.moveTo(cx, cy - 90); ctx.lineTo(cx, cy + 90); ctx.stroke();
      // střed
      ctx.beginPath(); ctx.arc(cx, cy, 5, 0, Math.PI * 2); ctx.fillStyle = '#ff5c6c'; ctx.fill();
      ctx.beginPath(); ctx.arc(cx, cy, 9, 0, Math.PI * 2); ctx.strokeStyle = 'rgba(255,92,108,0.8)'; ctx.lineWidth = 2; ctx.stroke();
      // popisky (se stínem kvůli čitelnosti nad mapou)
      ctx.shadowColor = 'rgba(0,0,0,0.9)'; ctx.shadowBlur = 6;
      ctx.fillStyle = 'rgba(232,237,242,0.95)'; ctx.font = '13px ui-monospace, monospace'; ctx.textAlign = 'left';
      ctx.fillText((T() === 'en' ? 'TARGET LOCKED' : 'CÍL ZAMĚŘEN'), 14, 24);
      ctx.fillStyle = 'rgba(56,232,200,0.95)';
      ctx.fillText(city.toUpperCase(), 14, H - 16);
      ctx.shadowBlur = 0;
      if (!reduced()) requestAnimationFrame(frame);
    }
    if (reduced()){ frame(0); return; }
    if (geoMapStarted) return; geoMapStarted = true;
    frame(0);
  }

  // ===================== WebRTC IP leak (panel 01) =====================
  // Lokální kandidáti jsou plně lokální (nic neodchází). Veřejná IP se zjistí
  // přes veřejný STUN server — odhalí reálnou IP i jiným kanálem než HTTP.
  function collectWebRTC(){
    var RTC = window.RTCPeerConnection || window.webkitRTCPeerConnection || window.mozRTCPeerConnection;
    if (!RTC){ S.webrtc = { unsupported: true }; renderWebRTC(); return; }
    var locals = {}, publics = {}, mdns = false;
    var reIP = /([0-9]{1,3}(\.[0-9]{1,3}){3})|([a-f0-9]{1,4}(:[a-f0-9]{0,4}){2,7})/i;
    var pc;
    try { pc = new RTC({ iceServers: [{ urls: 'stun:stun.l.google.com:19302' }] }); }
    catch(e){ S.webrtc = { blocked: true }; renderWebRTC(); return; }
    pc.createDataChannel('x');
    pc.onicecandidate = function(e){
      if (!e || !e.candidate || !e.candidate.candidate){ finish(); return; }
      var c = e.candidate.candidate;
      if (/\.local/i.test(c)) { mdns = true; }
      var m = c.match(reIP);
      if (m){
        var ip = m[0];
        if (/ typ host /.test(c) || / typ prflx /.test(c)) locals[ip] = 1;
        if (/ typ srflx /.test(c)) publics[ip] = 1;
      }
    };
    pc.createOffer().then(function(o){ return pc.setLocalDescription(o); }).catch(function(){});
    var done = false;
    function finish(){
      if (done) return; done = true;
      S.webrtc = { locals: Object.keys(locals), publics: Object.keys(publics), mdns: mdns };
      renderWebRTC();
      try { pc.close(); } catch(_){}
    }
    setTimeout(finish, 2500);
  }
  function renderWebRTC(){
    var w = S.webrtc; if (!w) return;
    if (w.unsupported){ set('rtc-local', tr('nepodporováno','unsupported')); set('rtc-public', tr('nepodporováno','unsupported')); return; }
    if (w.blocked){ set('rtc-local', tr('blokováno','blocked')); set('rtc-public', tr('blokováno','blocked')); return; }
    if (w.locals && w.locals.length) set('rtc-local', w.locals.join(', '), 'danger');
    else set('rtc-local', w.mdns ? tr('skryto (mDNS chrání)','hidden (mDNS protects)') : '—');
    var pub = w.publics && w.publics.length;
    set('rtc-public', pub ? w.publics.join(', ') : '—', pub ? 'danger' : '');
