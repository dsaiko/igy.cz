    if (m.unsupported || m.error){ set('media-cam', '—'); set('media-mic', '—'); return; }
    set('media-cam', m.cams + tr(m.cams===1?' kamera':' kamer', m.cams===1?' camera':' cameras'), m.cams ? 'danger' : '');
