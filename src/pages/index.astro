  // Hrubý (schválně drzý) odhad zařízení a jeho ceny z GPU a UA.
  function guessDevice(){
    var gpu = getGPU() || '', ua = navigator.userAgent;
    var m = gpu.match(/Apple (M\d[A-Za-z ]*)/);
    if (m) return { name: 'MacBook / Mac (' + m[1].trim() + ')', price: tr('~40–90 tis. Kč', '~$2000–4000') };
    if (/\b(iPhone)\b/.test(ua)) return { name: 'iPhone', price: tr('~15–35 tis. Kč', '~$700–1500') };
    if (/\b(iPad)\b/.test(ua)) return { name: 'iPad', price: tr('~12–30 tis. Kč', '~$600–1300') };
    if (/Android/.test(ua)) return { name: tr('Android telefon/tablet', 'Android phone/tablet'), price: tr('~5–30 tis. Kč', '~$200–1300') };
    var rtx = gpu.match(/(RTX|GTX)\s?\d{3,4}\s?(Ti|Super)?/i);
    if (rtx) return { name: tr('herní PC (NVIDIA ', 'gaming PC (NVIDIA ') + rtx[0].trim() + ')', price: tr('~25–60 tis. Kč', '~$1200–3000') };
    var rad = gpu.match(/Radeon[^,)]*/i);
    if (rad) return { name: 'PC (' + rad[0].trim() + ')', price: tr('~15–45 tis. Kč', '~$700–2200') };
    if (/Intel/i.test(gpu)) return { name: tr('kancelářský/laptop (Intel grafika)', 'office/laptop (Intel graphics)'), price: tr('~10–25 tis. Kč', '~$500–1200') };
    return null;
  }

