  // ===================== 04 · OTISK =====================
  // cyrb53 hash → krátký hex
  function cyrb53(str, seed){
    seed = seed || 0;
    var h1 = 0xdeadbeef ^ seed, h2 = 0x41c6ce57 ^ seed;
    for (var i = 0, ch; i < str.length; i++){
      ch = str.charCodeAt(i);
      h1 = Math.imul(h1 ^ ch, 2654435761);
      h2 = Math.imul(h2 ^ ch, 1597334677);
    }
    h1 = Math.imul(h1 ^ (h1>>>16), 2246822507) ^ Math.imul(h2 ^ (h2>>>13), 3266489909);
    h2 = Math.imul(h2 ^ (h2>>>16), 2246822507) ^ Math.imul(h1 ^ (h1>>>13), 3266489909);
    return (4294967296 * (2097151 & h2) + (h1>>>0)).toString(16);
  }
  function getGL(){
    try {
      var c = document.createElement('canvas');
      return c.getContext('webgl') || c.getContext('experimental-webgl');
    } catch(e){ return null; }
  }
  function getGPU(){
    var gl = getGL(); if (!gl) return null;
    try {
      var ext = gl.getExtension('WEBGL_debug_renderer_info');
      if (ext) return gl.getParameter(ext.UNMASKED_RENDERER_WEBGL);
      return gl.getParameter(gl.RENDERER);
    } catch(e){ return null; }
  }
  function canvasFP(){
    try {
      var c = document.createElement('canvas'); c.width = 280; c.height = 60;
      var ctx = c.getContext('2d');
      ctx.textBaseline = 'top'; ctx.font = '16px "Arial"';
      ctx.fillStyle = '#f60'; ctx.fillRect(0,0,140,30);
      ctx.fillStyle = '#069'; ctx.fillText('I Google You · igy.cz 🛰', 4, 8);
      ctx.fillStyle = 'rgba(56,232,200,0.7)'; ctx.fillText('I Google You · igy.cz 🛰', 6, 20);
      ctx.beginPath(); ctx.arc(220, 30, 18, 0, Math.PI*2); ctx.fillStyle='rgba(255,92,108,0.6)'; ctx.fill();
      return cyrb53(c.toDataURL());
    } catch(e){ return null; }
  }
  function webglFP(){
    var gl = getGL(); if (!gl) return null;
    try {
      var parts = [];
      var keys = ['VERSION','SHADING_LANGUAGE_VERSION','VENDOR','RENDERER','MAX_TEXTURE_SIZE','MAX_VIEWPORT_DIMS','MAX_RENDERBUFFER_SIZE'];
      keys.forEach(function(k){ try { parts.push(k + '=' + gl.getParameter(gl[k])); } catch(e){} });
      var ext = gl.getSupportedExtensions(); if (ext) parts.push(ext.join(','));
      return cyrb53(parts.join('|'));
    } catch(e){ return null; }
  }
  function audioFP(){
    return new Promise(function(resolve){
      try {
        var OAC = window.OfflineAudioContext || window.webkitOfflineAudioContext;
        if (!OAC){ resolve(null); return; }
        var ctx = new OAC(1, 5000, 44100);
        var osc = ctx.createOscillator(); osc.type = 'triangle'; osc.frequency.value = 10000;
        var comp = ctx.createDynamicsCompressor();
        osc.connect(comp); comp.connect(ctx.destination); osc.start(0);
        ctx.startRendering();
        ctx.oncomplete = function(e){
          var d = e.renderedBuffer.getChannelData(0); var sum = 0;
          for (var i = 4000; i < 5000; i++) sum += Math.abs(d[i]);
          resolve(cyrb53(String(sum)));
          try { osc.disconnect(); comp.disconnect(); } catch(_){}
        };
        setTimeout(function(){ resolve(null); }, 1500);
      } catch(e){ resolve(null); }
    });
  }
  function fontFP(){
    var base = ['monospace','sans-serif','serif'];
    var test = ['Arial','Calibri','Cambria','Comic Sans MS','Courier New','Georgia',
      'Helvetica Neue','Impact','Tahoma','Times New Roman','Trebuchet MS','Verdana',
      'Segoe UI','Roboto','Menlo','Monaco','Consolas','Ubuntu','Cantarell','DejaVu Sans'];
    var s = document.createElement('span');
    s.style.cssText = 'position:absolute;left:-9999px;font-size:72px;';
    s.textContent = 'mmmmmmmmmmlli';
    document.body.appendChild(s);
    function dims(font){ s.style.fontFamily = font; return s.offsetWidth + 'x' + s.offsetHeight; }
    var baseDims = {}; base.forEach(function(b){ baseDims[b] = dims(b); });
    var found = [];
    test.forEach(function(f){
      for (var i = 0; i < base.length; i++){
        if (dims("'" + f + "'," + base[i]) !== baseDims[base[i]]){ found.push(f); break; }
      }
    });
    document.body.removeChild(s);
    return found;
  }

