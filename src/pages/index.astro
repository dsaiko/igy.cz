  // Odvození nainstalovaného softwaru/OS z detekovaných fontů (best-effort).
  function softwareFromFonts(fonts){
    var has = {}; (fonts||[]).forEach(function(f){ has[f] = 1; });
    var out = [];
    if (has['Calibri'] || has['Cambria']) out.push('MS Office');
    if (has['Segoe UI']) out.push('Windows');
    if (has['Helvetica Neue'] || has['Menlo'] || has['Monaco']) out.push('macOS');
    if (has['Ubuntu'] || has['Cantarell'] || has['DejaVu Sans']) out.push('Linux');
