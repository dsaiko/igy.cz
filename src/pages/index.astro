  function animateFpId(fid){
    var idEl = document.getElementById('fp-id'); if (!idEl) return;
    if (reduced()){ idEl.textContent = fid; return; }
    var target = fid.split(''), glyphs = '0123456789ABCDEF', frame = 0;
    var iv = setInterval(function(){
      frame++;
      idEl.textContent = target.map(function(ch, i){
        return (frame > i*2+4) ? ch : glyphs[(frame + i) % 16];
